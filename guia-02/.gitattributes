# Forzar LF en todos los archivos de texto
# Soluciona problemas de CRLF cuando se montan archivos
# de Windows en contenedores Linux

*          text=auto eol=lf

# Archivos que NUNCA deben convertirse
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.tar.gz    binary
*.deb       binary
*.exe       binary
*.dll       binary
