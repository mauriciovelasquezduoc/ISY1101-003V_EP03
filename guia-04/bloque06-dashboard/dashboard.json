{
  "widgets": [
    {
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 24,
      "height": 1,
      "properties": {
        "markdown": "# Dashboard de Observabilidad — EKS Cluster: laboratorio-ep03-eks\nNamespace: ep03 | Servicios: backend, database, frontend"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "CPU por Pod (%)",
        "metrics": [
          ["ContainerInsights", "pod_cpu_utilization", "ClusterName", "laboratorio-ep03-eks", "Namespace", "ep03", "Pod", "ep03-backend", {"stat": "Average", "period": 60}],
          ["...", "ep03-frontend", {"stat": "Average", "period": 60}],
          ["...", "ep03-database", {"stat": "Average", "period": 60}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Memoria por Pod (%)",
        "metrics": [
          ["ContainerInsights", "pod_memory_working_set", "ClusterName", "laboratorio-ep03-eks", "Namespace", "ep03", "Pod", "ep03-backend", {"stat": "Average", "period": 60}],
          ["...", "ep03-frontend", {"stat": "Average", "period": 60}],
          ["...", "ep03-database", {"stat": "Average", "period": 60}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 1,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Trafico de Red (bytes)",
        "metrics": [
          ["ContainerInsights", "pod_network_rx_bytes", "ClusterName", "laboratorio-ep03-eks", "Namespace", "ep03", {"stat": "Sum", "period": 60}],
          ["...", "pod_network_tx_bytes", {"stat": "Sum", "period": 60}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 7,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Tiempo de Despliegue (segundos)",
        "metrics": [
          ["Custom", "DeployDuration", "Service", "backend", {"stat": "Average", "period": 300}],
          ["...", "frontend", {"stat": "Average", "period": 300}],
          ["...", "database", {"stat": "Average", "period": 300}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 300,
        "annotations": {
          "horizontal": [{"label": "Objetivo (<5 min)", "value": 300, "color": "#2ca02c"}]
        }
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 7,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Cobertura de Pruebas (%)",
        "metrics": [
          ["Custom", "TestCoverage", "Project", "backend", {"stat": "Average", "period": 86400}],
          ["...", "frontend", {"stat": "Average", "period": 86400}],
          ["...", "database", {"stat": "Average", "period": 86400}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 86400,
        "annotations": {
          "horizontal": [{"label": "Objetivo (>80%)", "value": 80, "color": "#2ca02c"}]
        }
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 7,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Errores en Logs",
        "metrics": [
          ["AWS/Logs", "IncomingBytes", "LogGroup", "/aws/eks/laboratorio-ep03-eks/application", {"stat": "Sum", "period": 300}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Estado de Pods",
        "metrics": [
          ["ContainerInsights", "pod_number_of_container_status_running", "ClusterName", "laboratorio-ep03-eks", "Namespace", "ep03", {"stat": "Average", "period": 60, "label": "Running"}],
          ["...", "pod_number_of_container_status_pending", {"stat": "Average", "period": 60, "label": "Pending"}],
          ["...", "pod_number_of_container_status_failed", {"stat": "Average", "period": 60, "label": "Failed", "color": "#d62728"}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 60
      }
    },
    {
      "type": "metric",
      "x": 8,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Alarmas Activas",
        "metrics": [
          ["AWS/CloudWatch", "AlarmState", "AlarmName", "laboratorio-ep03-eks-backend-errors", {"stat": "Maximum", "period": 300}],
          ["...", "laboratorio-ep03-eks-pods-availability", {"stat": "Maximum", "period": 300}],
          ["...", "laboratorio-ep03-eks-high-cpu", {"stat": "Maximum", "period": 300}],
          ["...", "laboratorio-ep03-eks-high-memory", {"stat": "Maximum", "period": 300}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 16,
      "y": 13,
      "width": 8,
      "height": 6,
      "properties": {
        "title": "Numero de Despliegues",
        "metrics": [
          ["Custom", "DeployCount", "Service", "backend", {"stat": "Sum", "period": 86400}],
          ["...", "frontend", {"stat": "Sum", "period": 86400}],
          ["...", "database", {"stat": "Sum", "period": 86400}]
        ],
        "view": "timeSeries",
        "region": "us-east-1",
        "period": 86400,
        "stacked": true
      }
    },
    {
      "type": "log",
      "x": 0,
      "y": 19,
      "width": 24,
      "height": 6,
      "properties": {
        "title": "Ultimos Errores en Logs",
        "query": "SOURCE '/aws/eks/laboratorio-ep03-eks/application' | fields @timestamp, @message | filter @message like /ERROR|Exception/ | sort @timestamp desc | limit 20",
        "region": "us-east-1",
        "view": "table"
      }
    }
  ]
}
